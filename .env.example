# =============================================================================
# StudyOS Backend — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env.
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_ENV=development                        # development | staging | production
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-long-random-secret
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ---------------------------------------------------------------------------
# Database (PostgreSQL 15)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://studyos:studyos@localhost:5432/studyos
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# JWT
# ---------------------------------------------------------------------------
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------------------------------------------------------------------------
# AI (NVIDIA NIM — OpenAI-compatible endpoint)
# ---------------------------------------------------------------------------
NVIDIA_API_KEY=nvapi-...
OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
OPENAI_MODEL=openai/gpt-oss-120b
AI_CACHE_TTL_SECONDS=86400         # 24 hours
AI_MAX_CHUNKS_PER_REQUEST=20
AI_TEMPERATURE=1.0
AI_TOP_P=1.0
AI_MAX_TOKENS=4096

# ---------------------------------------------------------------------------
# File storage
# ---------------------------------------------------------------------------
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=50

# ---------------------------------------------------------------------------
# SRS (SM-2)
# ---------------------------------------------------------------------------
MAX_CARDS_PER_SESSION=20
SM2_INITIAL_EASE_FACTOR=2.5
SM2_MIN_EASE_FACTOR=1.3
